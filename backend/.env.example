# ── Core POS settings ────────────────────────────────────────────────────────
JWT_SECRET=odoo_cafe_pos_super_secret_key
DB_PATH=pos.db
PORT=3001

# ── IBM watsonx.ai — Café Manager Chatbot Agent ──────────────────────────────
# Step 1: Create an IBM Cloud account at https://cloud.ibm.com
# Step 2: Create a watsonx.ai Runtime service instance (Lite tier is free)
# Step 3: Open https://dataplatform.cloud.ibm.com → New project → copy Project ID
# Step 4: Go to IBM Cloud → Manage → Access (IAM) → API keys → Create → copy key

WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Region where your WML service lives (us-south, eu-gb, eu-de, jp-tok, au-syd)
WATSONX_REGION=us-south

# Granite model to use (granite-3-3-8b-instruct is the recommended default)
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# Full inference URL (auto-built from WATSONX_REGION if left blank)
# WATSONX_URL=https://us-south.ml.cloud.ibm.com/ml/v1/text/chat?version=2024-05-31
